@model StudentAttendance.ViewModels.StudentFormViewModel

@{
    Layout = null;
    string action = ViewData["Action"]?.ToString() ?? "Create";
    ViewData["Title"] = action == "Create" ? "Add New Student" : "Edit Student";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/attendance-custom.css" />
</head>
<body>
    <!-- Top Navbar -->
    <div class="top-nav top-nav-alt d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Fingerprint Attendance System &mdash; Student Management</h5>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <a asp-controller="TeacherDashboard" asp-action="Index" class="sidebar-link">Dashboard</a>
        <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reports</a>
        <a asp-controller="Students" asp-action="Index" class="sidebar-link active-alt">Students</a>
        <a asp-controller="StudentEnrollment" asp-action="Index" class="sidebar-link">Fingerprints</a>
        <a asp-controller="Admin" asp-action="Index" class="sidebar-link">Admin</a>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none text-muted fw-bold">
                <i class="bi bi-arrow-left me-1"></i> Back to Students
            </a>
        </div>

        <div class="card shadow-sm border-0" style="max-width: 800px;">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="mb-0 fw-bold">@ViewData["Title"]</h4>
                <p class="text-muted small mt-1">Provide the necessary details for the student record.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="@action" method="post">
                    @if (action == "Edit")
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ExternalId" class="form-label fw-bold text-muted">Student Code</label>
                            <input asp-for="ExternalId" class="form-control" placeholder="Leave blank to auto-generate (e.g. STU-2025-0412)" />
                            <span asp-validation-for="ExternalId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="FullName" class="form-label fw-bold text-muted">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="e.g., Mohammed Al-Rashidi" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold text-muted">Email (Optional)</label>
                            <input asp-for="Email" class="form-control" placeholder="student@university.edu" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Department" class="form-label fw-bold text-muted">Department <span class="text-danger">*</span></label>
                            <input asp-for="Department" class="form-control" placeholder="e.g., Information Systems" />
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="EnrollmentYear" class="form-label fw-bold text-muted">Enrollment Year <span class="text-danger">*</span></label>
                            <input asp-for="EnrollmentYear" class="form-control" />
                            <span asp-validation-for="EnrollmentYear" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="border-top pt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-dark px-4 fw-bold">Save Student</button>
                        <a asp-action="Index" class="btn btn-light border px-4 fw-bold text-muted">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
