@model List<StudentAttendance.ViewModels.StudentListViewModel>

@{
    Layout = null;
    ViewData["Title"] = "Student Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/attendance-custom.css" />
</head>
<body>
    <!-- Top Navbar -->
    <div class="top-nav top-nav-alt d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Fingerprint Attendance System &mdash; Student Management</h5>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <a asp-controller="TeacherDashboard" asp-action="Index" class="sidebar-link">Dashboard</a>
        <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reports</a>
        <a asp-controller="Students" asp-action="Index" class="sidebar-link active-alt">Students</a>
        <a asp-controller="StudentEnrollment" asp-action="Index" class="sidebar-link">Fingerprints</a>
        <a asp-controller="Admin" asp-action="Index" class="sidebar-link">Admin</a>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0 fw-bold">Students</h3>
            <a asp-action="Create" class="btn btn-dark px-4 fw-bold shadow-sm">
                <i class="bi bi-person-plus-fill me-2"></i> Add New Student
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Students Datatable Card -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
                <h5 class="mb-0 fw-bold text-muted">All Enrolled Students</h5>
            </div>
            <div class="card-body p-0 mt-3">
                <table class="table table-custom table-hover mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Student ID</th>
                            <th>Full Name</th>
                            <th>Department</th>
                            <th>Year</th>
                            <th>Fingerprint Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No students found. Click "Add New Student" to get started.</td>
                            </tr>
                        }
                        @foreach (var student in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-bold">@student.ExternalId</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="user-avatar user-avatar-sm me-2 bg-secondary bg-opacity-10 text-secondary">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        @student.FullName
                                    </div>
                                </td>
                                <td>@student.Department</td>
                                <td>@student.EnrollmentYear</td>
                                <td>
                                    @if (student.HasFingerprintEnrolled)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success">Enrolled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning">Missing</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        @if (!student.HasFingerprintEnrolled)
                                        {
                                            <a asp-controller="StudentEnrollment" asp-action="Index" asp-route-studentId="@student.Id" class="btn btn-sm btn-outline-primary" title="Enroll Fingerprint">
                                                <i class="bi bi-fingerprint"></i>
                                            </a>
                                        }
                                        <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@student.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this student?');" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
