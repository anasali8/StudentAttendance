@model StudentAttendance.ViewModels.EnrollmentViewModel

@{
    Layout = null;
    ViewData["Title"] = "Student Fingerprint Enrollment";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/attendance-custom.css" />
</head>
<body>

    <!-- Top Navbar -->
    <div class="top-nav top-nav-alt d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Fingerprint Attendance System</h5>
        <span class="text-light opacity-75">Admin Panel</span>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <a asp-controller="TeacherDashboard" asp-action="Index" class="sidebar-link">Dashboard</a>
        <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reports</a>
        <a asp-controller="Students" asp-action="Index" class="sidebar-link">Students</a>
        <a asp-controller="StudentEnrollment" asp-action="Index" class="sidebar-link active-alt">Fingerprints</a>
        <a asp-controller="Admin" asp-action="Index" class="sidebar-link">Admin</a>
    </div>

    <!-- Main Content -->
    <div class="main-content-padded">
        <div class="enrollment-box">
            <h4 class="page-title">Student Fingerprint Enrollment</h4>
            
            <partial name="_ToastNotifications" />

            <form asp-action="Index" method="post" id="enrollmentForm">
                <input type="hidden" asp-for="FingerprintBase64" id="fingerprintData" />

                <div class="row">
                    <!-- Left: Form Fields -->
                    <div class="col-md-7">
                        <div class="mb-3 row">
                            <label asp-for="StudentIdString" class="col-sm-3 col-form-label form-label text-end">Student ID:</label>
                            <div class="col-sm-8">
                                <input asp-for="StudentIdString" class="form-control" placeholder="e.g., STU-2025-0412" />
                                <span asp-validation-for="StudentIdString" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3 row">
                            <label asp-for="FullName" class="col-sm-3 col-form-label form-label text-end">Full Name:</label>
                            <div class="col-sm-8">
                                <input asp-for="FullName" class="form-control" placeholder="e.g., Mohammed Al-Rashidi" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3 row">
                            <label asp-for="Department" class="col-sm-3 col-form-label form-label text-end">Department:</label>
                            <div class="col-sm-8">
                                <input asp-for="Department" class="form-control" placeholder="e.g., Information Systems" />
                                <span asp-validation-for="Department" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4 row">
                            <label asp-for="Year" class="col-sm-3 col-form-label form-label text-end">Year:</label>
                            <div class="col-sm-8">
                                <input asp-for="Year" class="form-control" placeholder="e.g., 3rd Year" />
                                <span asp-validation-for="Year" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Fingerprint Area -->
                    <div class="col-md-5">
                        <div class="fingerprint-area">
                            <div class="fingerprint-icon-circle" title="Click to sync fingerprint from ZKTeco device" style="cursor: pointer;">
                                <i class="bi bi-fingerprint"></i>
                            </div>
                            <div class="text-primary fw-bold mb-2">Pull Fingerprint from Device</div>
                            <div class="small text-muted mb-4 px-3 text-center">
                                Have the student enroll on the physical ZKTeco machine first. Then, click the icon above to sync their template to the database.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-8 offset-md-2">
                        <div class="status-box" id="scannerStatus">
                            <span class="text-success fw-bold">✓ Ready</span> <span class="text-muted">— Waiting to sync with device...</span>
                        </div>
                        
                        <div class="mt-3">
                            <button type="submit" class="btn btn-enroll" id="btnEnroll">Enroll Fingerprint</button>
                            <button type="button" class="btn btn-clear">Clear Form</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/Scripts/Attendance/StudentEnrollment/enrollment.js"></script>
</body>
</html>
