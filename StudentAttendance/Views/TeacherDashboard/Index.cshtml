@model StudentAttendance.ViewModels.DashboardViewModel

@{
    Layout = null;
    ViewData["Title"] = "Teacher Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/attendance-custom.css" />
</head>
<body>

    <!-- Top Navbar -->
    <div class="top-nav d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Fingerprint Attendance System &mdash; Teacher Dashboard</h5>
        <div class="d-flex align-items-center gap-3">
            <span class="fw-bold">@Model.CourseName (@Model.CourseCode)</span>
            <form asp-action="EndSession" method="post" onsubmit="return confirm('Are you sure you want to end this session? Any student who hasn\'t checked in will be marked Absent.');">
                <input type="hidden" name="sessionId" value="@Model.ActiveLectureSessionId" />
                <input type="hidden" name="teacherId" value="2" />
                <button type="submit" class="btn btn-sm btn-danger fw-bold shadow-sm">
                    <i class="bi bi-stop-circle me-1"></i> End Session
                </button>
            </form>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <a asp-controller="TeacherDashboard" asp-action="Index" class="sidebar-link active-alt">Dashboard</a>
        <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reports</a>
        <a asp-controller="Students" asp-action="Index" class="sidebar-link">Students</a>
        <a asp-controller="StudentEnrollment" asp-action="Index" class="sidebar-link">Fingerprints</a>
        <a asp-controller="Admin" asp-action="Index" class="sidebar-link">Admin</a>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        
        <!-- Live Notification Banner -->
        <div id="signalr-notification" class="alert py-2 px-3 mb-3 small" style="display:none;" role="alert"></div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show small" role="alert">
                <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- KPI Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="kpi-card kpi-total">
                    <div class="kpi-title">Total Students</div>
                    <div class="kpi-value" id="kpi-total">@Model.TotalEnrolled</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="kpi-card kpi-present">
                    <div class="kpi-title">Present Today</div>
                    <div class="kpi-value" id="kpi-present">@Model.TotalPresent</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="kpi-card kpi-late">
                    <div class="kpi-title">Late Today</div>
                    <div class="kpi-value" id="kpi-late">@Model.TotalLate</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="kpi-card kpi-absent">
                    <div class="kpi-title">Absent Today</div>
                    <div class="kpi-value" id="kpi-absent">@(Model.TotalEnrolled - Model.TotalPresent - Model.TotalLate)</div>
                </div>
            </div>
        </div>

        <!-- Main Attendance Table -->
        <div class="card shadow-sm mb-4 border-0">
            <div class="card-header bg-white border-bottom-0 pt-3">
                <div class="section-header mb-0">Today's Attendance &mdash; @Model.CourseName (@Model.CourseCode)</div>
            </div>
            <div class="card-body p-0">
                <table class="table table-custom mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Student Name</th>
                            <th>Check-in Time</th>
                            <th>Delay</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="attendanceTableBody">

                        <!-- Dynamic Rows from Model -->
                        @{ int rowNum = 0; }
                        @foreach (var student in Model.Students)
                        {
                            rowNum++;
                            <tr id="row-@student.StudentId">
                                <td class="ps-4 text-muted">@rowNum</td>
                                <td class="fw-bold">@student.FullName</td>
                                <td id="time-@student.StudentId">@student.CheckInTime</td>
                                <td id="delay-@student.StudentId">@(student.Status == "Pending" || student.Status == "Absent" ? "—" : "-")</td>
                                <td id="status-@student.StudentId">
                                    @if (student.Status == "OnTime") { <span class="status-badge status-ontime">On Time</span> }
                                    else if (student.Status.Contains("Late")) { <span class="status-badge status-late">@student.Status</span> }
                                    else if (student.Status == "Pending") { <span class="status-badge" style="background:#f3f4f6;color:#6b7280;">Pending</span> }
                                    else { <span class="status-badge status-absent">@student.Status</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="row">
            <!-- At-Risk Students -->
            <div class="col-md-6">
                <div class="risk-box shadow-sm">
                    <div class="risk-header">⚠ At-Risk Students (AI Prediction)</div>
                    @{ var atRiskStudents = Model.Students.Where(s => s.RiskFlag != StudentAttendance.Core.Enums.RiskFlag.Low).OrderByDescending(s => s.AbsenceProbability).ToList(); }
                    @if (!atRiskStudents.Any())
                    {
                        <div class="risk-item">
                            <div class="text-muted small">No at-risk students detected for this session.</div>
                        </div>
                    }
                    @foreach (var atRisk in atRiskStudents)
                    {
                        <div class="risk-item">
                            <div>
                                <div class="fw-bold text-dark">@atRisk.FullName</div>
                                <div class="small text-muted">Risk Level: @atRisk.RiskFlag</div>
                            </div>
                            <div class="risk-percent">@(Math.Round(atRisk.AbsenceProbability * 100, 0))%</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Weekly Attendance Rate (Placeholder for Chart) -->
            <div class="col-md-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="section-header">Weekly Attendance Rate (%)</div>
                        <div class="d-flex align-items-end h-75 mt-3 gap-2 pb-2 border-bottom">
                            <div class="w-100 bg-success" style="height: 95%;" title="W1: 95%"></div>
                            <div class="w-100 bg-success" style="height: 92%;" title="W2: 92%"></div>
                            <div class="w-100 bg-success" style="height: 88%;" title="W3: 88%"></div>
                            <div class="w-100 bg-success" style="height: 91%;" title="W4: 91%"></div>
                            <div class="w-100 bg-success" style="height: 85%;" title="W5: 85%"></div>
                            <div class="w-100 bg-danger" style="height: 79%;" title="W6: 79%"></div>
                        </div>
                        <div class="d-flex justify-content-between text-muted small mt-1">
                            <span>W1</span><span>W2</span><span>W3</span><span>W4</span><span>W5</span><span>W6</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SignalR Client Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script src="~/Scripts/Attendance/TeacherDashboard/dashboard.js"></script>
</body>
</html>
