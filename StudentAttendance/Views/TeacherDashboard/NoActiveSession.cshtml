@model StudentAttendance.ViewModels.NoActiveSessionViewModel
@{
    Layout = null;
    ViewData["Title"] = "No Active Session";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/attendance-custom.css" />
</head>
<body>

    <!-- Top Navbar -->
    <div class="top-nav d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Fingerprint Attendance System &mdash; Teacher Dashboard</h5>
        <span class="text-light small" id="current-time"></span>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <a asp-controller="TeacherDashboard" asp-action="Index" class="sidebar-link active-alt">Dashboard</a>
        <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reports</a>
        <a asp-controller="Students" asp-action="Index" class="sidebar-link">Students</a>
        <a asp-controller="StudentEnrollment" asp-action="Index" class="sidebar-link">Fingerprints</a>
        <a asp-controller="Admin" asp-action="Index" class="sidebar-link">Admin</a>
    </div>

    <!-- Main Content -->
    <div class="main-content d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 56px);">
        <div class="text-center" style="max-width: 480px; width: 100%;">

            <div class="mb-4" style="font-size: 4rem; color: #9ca3af;">
                <i class="bi bi-calendar-check"></i>
            </div>

            <h3 class="fw-bold text-dark mb-2">Ready to Start Class?</h3>
            <p class="text-muted mb-4">
                Select a course below to immediately open a new lecture session and begin tracking attendance.
            </p>

            <div class="card border-0 shadow-sm mb-4 text-start">
                <div class="card-body p-4">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show small" role="alert">
                            <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="StartSession" method="post">
                        <input type="hidden" name="teacherId" value="@Model.TeacherId" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">Select Course</label>
                            <select name="courseId" class="form-select" required>
                                <option value="">-- Choose a course --</option>
                                @foreach (var course in Model.TeacherCourses)
                                {
                                    <option value="@course.CourseId">@course.CourseCode - @course.CourseName</option>
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 fw-bold py-2">
                            <i class="bi bi-play-circle-fill me-2"></i> Start Lecture Session
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Live clock
        function updateClock() {
            const el = document.getElementById('current-time');
            if (el) el.textContent = new Date().toLocaleTimeString('en-GB', { hour12: false });
        }
        setInterval(updateClock, 1000);
        updateClock();

        // Auto-refresh every 60 seconds to check if a session has become active
        setTimeout(() => location.reload(), 60000);
    </script>
</body>
</html>
