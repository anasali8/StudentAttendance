@model StudentAttendance.ViewModels.AdminManagementViewModel

@{
    Layout = null;
    ViewData["Title"] = "Admin Settings & User Management";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/attendance-custom.css" asp-append-version="true" />
</head>
<body>

<div class="app-wrapper">

    <!-- Sidebar -->
    <div class="sidebar">
        <a asp-controller="TeacherDashboard" asp-action="Index" class="sidebar-link">Dashboard</a>
        <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reports</a>
        <a asp-controller="Students" asp-action="Index" class="sidebar-link">Students</a>
        <a asp-controller="StudentEnrollment" asp-action="Index" class="sidebar-link">Fingerprints</a>
        <a asp-controller="Admin" asp-action="Index" class="sidebar-link active-alt">Admin</a>
    </div>

    <div class="app-body">

    <!-- Top Navbar -->
    <div class="top-nav top-nav-alt d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <button class="sidebar-toggle-btn" id="sidebarToggle" title="Toggle Menu">
                <i class="bi bi-list"></i>
            </button>
            <h5 class="mb-0">Fingerprint Attendance System &mdash; Administration</h5>
        </div>
        <div class="user-profile text-white opacity-75">
            <i class="bi bi-person-circle me-2"></i> System Admin
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="mb-0 fw-bold">User Management</h3>
            <button class="btn btn-dark px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="bi bi-person-plus-fill me-2"></i> Add New User
            </button>
        </div>

        <!-- Users Datatable Card -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
                <h5 class="mb-0 fw-bold text-muted">Current System Users</h5>
            </div>
            <div class="card-body p-0 mt-3 table-responsive">
                <table class="table table-custom table-hover mb-0 text-nowrap">
                    <thead>
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Username</th>
                            <th>System Role</th>
                            <th>Associated ID</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">@user.Id</td>
                                <td class="fw-bold">@user.Username</td>
                                <td>
                                    @if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-danger rounded-pill px-3">Admin</span>
                                    }
                                    else if (user.Role == "Teacher")
                                    {
                                        <span class="badge bg-primary rounded-pill px-3">Teacher</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill px-3">Student</span>
                                    }
                                </td>
                                <td><span class="text-muted">@user.AssociatedId</span></td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill px-3">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark rounded-pill px-3">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-secondary me-2 btn-edit-user" data-userid="@user.Id">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </button>
                                    <button class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success") btn-toggle-status" data-userid="@user.Id" data-status="@user.IsActive.ToString()">
                                        <i class="bi @(user.IsActive ? "bi-person-x-fill" : "bi-person-check-fill")"></i> @(user.IsActive ? "Deactivate" : "Activate")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Add New User Modal -->
    <div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
          <div class="modal-header bg-dark text-white border-0">
            <h5 class="modal-title fw-bold" id="addUserModalLabel"><i class="bi bi-person-plus me-2"></i> Add System User</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body p-4 bg-light">
            <form id="newUserForm">
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">USERNAME</label>
                    <input type="text" class="form-control form-control-lg border-0 shadow-sm" id="NewUsername" placeholder="Enter username..." />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">SYSTEM ROLE</label>
                    <select class="form-select form-select-lg border-0 shadow-sm" id="NewUserRole">
                        <option value="Student">Student</option>
                        <option value="Teacher">Teacher / Instructor</option>
                        <option value="Admin">System Administrator</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small">ASSOCIATED RECORD ID (Teacher/Student ID)</label>
                    <input type="text" class="form-control form-control-lg border-0 shadow-sm" id="AssociatedId" placeholder="e.g. S-202301 or T-402" />
                    <div class="form-text text-muted">Leave blank if assigning a System Administrator role.</div>
                </div>
            </form>
          </div>
          <div class="modal-footer bg-light border-0">
            <button type="button" class="btn btn-light border px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-dark px-4 fw-bold" id="btnSaveUser">Create User</button>
          </div>
        </div>
      </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/Attendance/Admin/admin.js"></script>
    <partial name="_SidebarToggle" />
    </div><!-- /.app-body -->
</div><!-- /.app-wrapper -->
</body>
</html>
